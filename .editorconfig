# EditorConfig - Enforces consistent coding styles across IDEs and platforms.
# Highly optimized for VenueMind AI Enterprise Codebase.
# https://editorconfig.org

root = true

# --- Global Defaults ---
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# --- JavaScript / React Source Files ---
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
quote_type = single

# --- Style / Markup Sheets ---
[*.{css,scss,less,html,htm}]
indent_style = space
indent_size = 2

# --- Configuration & Structured Data ---
[*.{json,json5}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

# --- Markdown Documentation ---
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# --- DevOps & Infrastructure Configs ---
[Dockerfile]
indent_style = space
indent_size = 2

[docker-compose.yml]
indent_style = space
indent_size = 2

# --- Scripts & System Files ---
[*.{sh,bash,zsh}]
end_of_line = lf
indent_style = space
indent_size = 2

[*.bat]
end_of_line = crlf

# --- Graphic Vector Assets ---
[*.svg]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
