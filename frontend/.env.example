# ==============================================================================
# VenueMind AI - Frontend Environment Configuration Template
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to `.env` (or `.env.local` for local overrides) in the same directory.
# 2. Modify values as needed for your specific deployment environment.
# 3. DO NOT commit actual secrets or sensitive credentials into this file or any Git repo.
#
# NOTE: In Vite-powered applications, only environment variables prefixed with 
# `VITE_` are exposed to the client-side code to prevent accidental leaks.
# ==============================================================================

# --- API Configuration ---
# The absolute base URL of the VenueMind AI backend API service.
# For local development: http://localhost:3000
# For production: The secure HTTPS domain of the backend server.
# Fallback: If not specified, Vite development proxy configured in `vite.config.js` will route requests.
VITE_API_URL=http://localhost:3000

# --- App Meta Info ---
# The semantically versioned release identifier injected during build time.
VITE_APP_VERSION=1.3.0

# --- Feature Flags & Feature Controls ---
# Toggles the speech recognition (Web Speech API) and Text-To-Speech (TTS) voice engines.
# Expected values: true | false
VITE_ENABLE_VOICE=true

# Enables offline caching prompts, PWA status bars, and Service Worker listeners.
# Expected values: true | false
VITE_ENABLE_OFFLINE_MODE=true

# --- Observability & Analytics ---
# Set to 'true' to enable Console-based Performance Metrics logging (LCP, FID, CLS, FCP) in production.
# Expected values: true | false
VITE_ENABLE_PERFORMANCE_METRICS=false
